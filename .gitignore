# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.claude
plan*.md
kb_plan.md
visual_script_editor_roadmap.md
WORKING_AI_CONFIG.md
semantic_intent_matching_plan.md
build_results.txt
lint_results.txt
dexit_knowledge_base.json
lint_json.json

# local SQL utility scripts (not migrations)
/analytics-schema.sql
/database-setup.sql
/fix-user-presence.sql
/node-locks.sql

# dev scripts (local utilities, migrations, debug tools)
# Note: we want to track the scripts themselves, but ignore their output
scripts/*.txt
scripts/*.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# diagnostic and temporary files
*.json
!package.json
!package-lock.json
!tsconfig.json
!next.config.json
!eslint.config.json
!*.config.json
*.txt
!README.md
build_output.txt
diagnostics_output.txt
json_files.txt
db_state.json
all_updates.json
products_ids.json
